# =============================================================================
# Platform — Environment Variables Template
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real secrets.
# Production secrets are managed via AWS Secrets Manager.
# =============================================================================

# --- App ---
NODE_ENV=development
# LOG_LEVEL=info

# --- SA Platform ---
# SA_API_URL=http://localhost:3001
# SA_DATABASE_URL=postgresql://user:password@localhost:5432/platform_sa_dev

# --- PT Platform ---
# PT_API_URL=http://localhost:3002
# PT_DATABASE_URL=postgresql://user:password@localhost:5432/platform_pt_dev

# --- AWS (local dev only — use IAM roles in CI/prod) ---
# AWS_REGION=af-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Shared secrets (resolved from AWS Secrets Manager in prod) ---
# DATABASE_PASSWORD=
# JWT_SECRET=
# INTERNAL_API_KEY=
